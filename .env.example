# Public site URL (production)
NEXT_PUBLIC_SITE_URL=https://www.uptowngaming.net

# start.gg GraphQL — create token at https://www.start.gg/admin/profile/developer
STARTGG_API_TOKEN=

# Organizer account(s) — numeric owner id and/or user slug (e.g. cd699316). Comma-separate multiple.
# Example: STARTGG_OWNER_ID=2048780,549977
# Tip: tournament(slug: "tournament/…") { owner { id } } or user(slug: "user/…") { id } in API Explorer.
STARTGG_OWNER_ID=
# Optional alias: STARTGG_OWNER_IDS=2048780,549977

# Optional: show events for this tournament only (slug without "tournament/" prefix)
# STARTGG_TOURNAMENT_SLUG=up-the-block-56-11-18-11-24
